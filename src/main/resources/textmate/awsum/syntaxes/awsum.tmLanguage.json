{
  "name": "Awsum",
  "scopeName": "source.awsum",
  "fileTypes": ["aww"],
  "patterns": [
    { "include": "#block_comment" },
    { "include": "#line_comment" },
    { "include": "#string" },
    { "include": "#import" },
    { "include": "#type_declaration" },
    { "include": "#type_signature" },
    { "include": "#function_definition" },
    { "include": "#let_binding_ascription" },
    { "include": "#keywords" },
    { "include": "#numeric_literal" },
    { "include": "#operators" },
    { "include": "#qualified_value" },
    { "include": "#parens" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "line_comment": {
      "name": "comment.line.double-dash.awsum",
      "begin": "--",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.awsum" }
      },
      "end": "$"
    },
    "block_comment": {
      "name": "comment.block.awsum",
      "begin": "\\{-(?!#)",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.begin.awsum" }
      },
      "end": "-\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.end.awsum" }
      },
      "patterns": [{ "include": "#block_comment" }]
    },

    "string": {
      "name": "string.quoted.double.awsum",
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.awsum" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.awsum" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.awsum",
          "match": "\\\\(?:[ntr\"\\\\0])"
        },
        {
          "name": "invalid.illegal.escape.awsum",
          "match": "\\\\."
        }
      ]
    },

    "import": {
      "name": "meta.import.awsum",
      "begin": "^(import)(?![A-Za-z0-9_'])",
      "beginCaptures": {
        "1": { "name": "keyword.control.import.awsum" }
      },
      "end": "$",
      "patterns": [
        { "include": "#module_path" },
        { "include": "#line_comment" }
      ]
    },

    "module_path": {
      "patterns": [
        {
          "name": "entity.name.namespace.awsum",
          "match": "(?<![A-Za-z0-9_'])[A-Z][A-Za-z0-9_']*(?![A-Za-z0-9_'])"
        },
        {
          "name": "punctuation.accessor.dot.awsum",
          "match": "\\."
        }
      ]
    },

    "type_declaration": {
      "name": "meta.type-declaration.awsum",
      "begin": "^(?:(empty)\\s+)?(type)(?![A-Za-z0-9_'])",
      "beginCaptures": {
        "1": { "name": "keyword.other.type-definition.empty.awsum" },
        "2": { "name": "keyword.other.type-definition.awsum" }
      },
      "end": "$",
      "patterns": [
        { "name": "keyword.operator.assignment.awsum", "match": "=" },
        { "name": "keyword.operator.pipe-forward.awsum", "match": "\\|>" },
        { "name": "keyword.operator.pipe.awsum", "match": "\\|" },
        { "name": "entity.name.type.awsum", "match": "(?<![A-Za-z0-9_'])_?[A-Z][A-Za-z0-9_']*(?![A-Za-z0-9_'])" },
        { "name": "variable.type.awsum", "match": "(?<![A-Za-z0-9_'])[a-z_][A-Za-z0-9_']*(?![A-Za-z0-9_'])" },
        { "include": "#line_comment" }
      ]
    },

    "type_signature": {
      "name": "meta.type-signature.awsum",
      "begin": "^(?:([a-z_][A-Za-z0-9_']*)|(\\(\\+\\+\\)))\\s*(:)\\s*",
      "beginCaptures": {
        "1": { "name": "entity.name.function.awsum" },
        "2": { "name": "entity.name.function.awsum" },
        "3": { "name": "punctuation.separator.type.annotation.awsum" }
      },
      "end": "(?=\\s*(?:$|--))",
      "patterns": [{ "include": "#type_expr" }]
    },

    "type_expr": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.awsum",
          "match": "->"
        },
        {
          "name": "support.type.awsum",
          "match": "(?<![A-Za-z0-9_'])(?:_?[A-Z][A-Za-z0-9_']*)(?:\\.(?:_?[A-Z][A-Za-z0-9_']*))*(?![A-Za-z0-9_'])"
        },
        {
          "name": "variable.type.awsum",
          "match": "(?<![A-Za-z0-9_'])[a-z_][A-Za-z0-9_']*(?![A-Za-z0-9_'])"
        },
        { "include": "#parens" }
      ]
    },

    "function_definition": {
      "name": "meta.function.definition.awsum",
      "begin": "^(?:([a-z_][A-Za-z0-9_']*)(?![A-Za-z0-9_'])|(\\(\\+\\+\\)))(?!\\s*:)",
      "beginCaptures": {
        "1": { "name": "entity.name.function.awsum" },
        "2": { "name": "entity.name.function.awsum" }
      },
      "end": "(=)",
      "endCaptures": {
        "1": { "name": "keyword.operator.assignment.awsum" }
      },
      "patterns": [
        {
          "name": "variable.parameter.function.awsum",
          "match": "(?<![A-Za-z0-9_'])[a-z_][A-Za-z0-9_']*(?![A-Za-z0-9_'])"
        }
      ]
    },

    "qualified_value": {
      "name": "meta.qualified.value.awsum",
      "match": "(?<![A-Za-z0-9_'])(?:[A-Z][A-Za-z0-9_']*\\.)+([a-z][A-Za-z0-9_']*)(?![A-Za-z0-9_'])",
      "captures": {
        "1": { "name": "support.function.awsum" }
      }
    },

    "let_binding_ascription": {
      "comment": "Highlights the `:` in `let n : T = …` (and the let keyword in the same hit) so the ascription separator gets the same scope as the one in top-level signatures. The type itself isn't entered as a region — the trailing `T = …` is handled by ordinary identifier / operator rules. Matches the standalone `let-in` form; subsequent bindings in the multi-binding layout (no leading `let`) keep the plain identifier coloring.",
      "match": "(?<![A-Za-z0-9_'])(let)\\s+([a-z_][A-Za-z0-9_']*)\\s*(:)",
      "captures": {
        "1": { "name": "keyword.control.let.awsum" },
        "3": { "name": "punctuation.separator.type.annotation.awsum" }
      }
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.case.awsum",
          "match": "(?<![A-Za-z0-9_'])case(?![A-Za-z0-9_'])"
        },
        {
          "name": "keyword.control.of.awsum",
          "match": "(?<![A-Za-z0-9_'])of(?![A-Za-z0-9_'])"
        },
        {
          "name": "keyword.control.do.awsum",
          "match": "(?<![A-Za-z0-9_'])do(?![A-Za-z0-9_'])"
        },
        {
          "name": "keyword.control.let.awsum",
          "match": "(?<![A-Za-z0-9_'])(?:let|in)(?![A-Za-z0-9_'])"
        }
      ]
    },

    "numeric_literal": {
      "name": "constant.numeric.integer.awsum",
      "match": "(?<![A-Za-z0-9_'])-?\\d+(?:_\\d+)*(?![A-Za-z0-9_'])"
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.concat.awsum",
          "match": "\\+\\+"
        },
        {
          "name": "keyword.operator.arrow.awsum",
          "match": "->"
        },
        {
          "name": "keyword.operator.bind.awsum",
          "match": "<-"
        },
        {
          "name": "keyword.operator.lambda.awsum",
          "match": "\\\\"
        },
        {
          "name": "keyword.operator.pipe-forward.awsum",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.pipe.awsum",
          "match": "\\|"
        },
        {
          "name": "punctuation.separator.type.annotation.awsum",
          "match": ":"
        },
        {
          "name": "punctuation.accessor.dot.awsum",
          "match": "\\."
        }
      ]
    },

    "parens": {
      "patterns": [
        { "name": "punctuation.section.parens.begin.awsum", "match": "\\(" },
        { "name": "punctuation.section.parens.end.awsum", "match": "\\)" }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.awsum",
          "match": "(?<![A-Za-z0-9_'])_?[A-Z][A-Za-z0-9_']*(?![A-Za-z0-9_'])"
        },
        {
          "name": "variable.other.readwrite.awsum",
          "match": "(?<![A-Za-z0-9_'])[a-z_][A-Za-z0-9_']*(?![A-Za-z0-9_'])"
        }
      ]
    }
  }
}
